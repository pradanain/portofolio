---
import {
  badgeClass,
  buttonClass,
  cardClass,
  cardContentClass,
  cardDescriptionClass,
  cardHeaderClass,
  cardTitleClass,
  cx
} from "@/lib/ui";

type Service = {
  title: string;
  description: string;
  tags: string[];
  category: "Web" | "Backend" | "Data" | "Soft Skill";
};

const isEn = Astro.url.pathname.includes('/en');

const servicesId: Service[] = [
  {
    title: "Front-end Development",
    description: "Membangun antarmuka modern yang responsif dan mudah dipakai.",
    tags: ["React", "Tailwind", "UI/UX", "Responsive"],
    category: "Web"
  },
  {
    title: "Back-end Development",
    description: "Mengembangkan API dan logika server yang aman serta terhubung ke database.",
    tags: ["PHP", "Laravel", "MySQL", "PostgreSQL", "REST API"],
    category: "Backend"
  },
  {
    title: "Dashboard",
    description: "Menyusun dashboard metrik yang ringkas dan mudah dipahami untuk monitoring.",
    tags: ["KPI", "Data Viz", "SQL", "Reporting"],
    category: "Data"
  },
  {
    title: "Automation",
    description: "Otomatisasi workflow dan pengujian web dengan scripting yang repeatable.",
    tags: ["Python", "Selenium", "Playwright", "Automation"],
    category: "Backend"
  },
  {
    title: "Data Engineering",
    description: "Membangun pipeline data untuk eksperimen, analisis, dan pemrosesan yang rapi di notebook maupun produksi.",
    tags: ["Python", "R", "Google Colab", "ETL/ELT"],
    category: "Data"
  },
  {
    title: "Public Speaking & Problem Solving",
    description: "Menyampaikan ide dan insight teknis secara jelas serta memecahkan masalah secara terstruktur.",
    tags: ["Public Speaking", "Problem Solving"],
    category: "Soft Skill"
  }
];

const servicesEn: Service[] = [
  {
    title: "Front-end Development",
    description: "Building modern interfaces that are responsive and user-friendly.",
    tags: ["React", "Tailwind", "UI/UX", "Responsive"],
    category: "Web"
  },
  {
    title: "Back-end Development",
    description: "Developing secure APIs and server logic connected to databases.",
    tags: ["PHP", "Laravel", "MySQL", "PostgreSQL", "REST API"],
    category: "Backend"
  },
  {
    title: "Dashboard",
    description: "Creating concise and easy-to-understand metric dashboards for monitoring.",
    tags: ["KPI", "Data Viz", "SQL", "Reporting"],
    category: "Data"
  },
  {
    title: "Automation",
    description: "Automating workflows and web testing with repeatable scripting.",
    tags: ["Python", "Selenium", "Playwright", "Automation"],
    category: "Backend"
  },
  {
    title: "Data Engineering",
    description: "Building data pipelines for experiments, analysis, and clean processing in notebooks or production.",
    tags: ["Python", "R", "Google Colab", "ETL/ELT"],
    category: "Data"
  },
  {
    title: "Public Speaking & Problem Solving",
    description: "Delivering ideas and technical insights clearly and solving problems systematically.",
    tags: ["Public Speaking", "Problem Solving"],
    category: "Soft Skill"
  }
];

const services = isEn ? servicesEn : servicesId;

const stack = [
  "PHP",
  "Laravel",
  "React",
  "Tailwind",
  "MySQL",
  "PostgreSQL",
  "Python",
  "R",
  "Google Colab",
  "Selenium",
  "Playwright",
  "Public Speaking",
  "Problem Solving"
];

const filters = ["All", "Web", "Backend", "Data", "Soft Skill"] as const;
const sectionTitle = isEn ? "Skills" : "Keahlian";
const sectionDesc = isEn 
  ? "Focused on front-end, back-end development, data engineering, automation, and dashboards, with a commitment to continuous learning and improving solution quality."
  : "Berfokus pada pengembangan front-end, back-end, data engineering, automation, dan dashboard, dengan komitmen untuk terus belajar dan meningkatkan kualitas solusi.";
const serviceCountLabel = isEn ? "services" : "layanan";
---

<section id="keahlian" class="section">
  <div aria-hidden="true" class="section-bg [mask-image:linear-gradient(to_bottom,transparent,white_10%,white_90%,transparent)]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_42%),radial-gradient(circle_at_bottom_right,rgba(14,165,233,0.08),transparent_40%)]"></div>
  </div>

  <div class="container relative space-y-10" data-services-filter data-initial-filter="All">
    <div class="mx-auto max-w-2xl space-y-3 text-center">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{sectionTitle}</h2>
      <p class="text-base leading-relaxed text-muted-foreground md:text-lg">
        {sectionDesc}
      </p>
    </div>

    <div class="space-y-8">
      <div class="flex flex-wrap items-center gap-2">
        {filters.map((filter) => (
          <button
            type="button"
            class={buttonClass({
              variant: filter === "All" ? "default" : "secondary",
              size: "sm",
              className: "rounded-full"
            })}
            aria-pressed={filter === "All" ? "true" : "false"}
            data-filter-button
            data-filter-value={filter}
          >
            {filter}
          </button>
        ))}

        <span class="ml-1 text-xs text-muted-foreground" data-filter-count>{services.length} {serviceCountLabel}</span>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-filter-grid>
        {services.map((service, idx) => (
          <article
            class={cardClass(
              "group h-full overflow-hidden border-border/60 bg-card/70 transition-all duration-300 hover:-translate-y-2 hover:bg-card hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] dark:hover:shadow-[0_8px_30px_rgba(255,255,255,0.05)] reveal-on-scroll"
            )}
            data-service-card
            data-category={service.category}
          >
            <div class={cx(cardHeaderClass, "space-y-3")}>
              <div class="flex items-start justify-between gap-3">
                <h3 class={cx(cardTitleClass, "text-lg")}>{service.title}</h3>

                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-border/60 bg-background/70 text-xs text-muted-foreground">
                  {String(idx + 1).padStart(2, "0")}
                </span>
              </div>

              <p class={cx(cardDescriptionClass, "leading-relaxed")}>{service.description}</p>
            </div>

            <div class={cx(cardContentClass, "space-y-3")}>
              <div class="flex flex-wrap gap-2">
                {service.tags.map((item) => (
                  <span class={badgeClass({ variant: "outline", className: "rounded-full" })}>
                    {item}
                  </span>
                ))}
              </div>

              <div class="pt-1">
                <span class={badgeClass({ variant: "secondary", className: "rounded-full" })}>
                  {service.category}
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="relative overflow-hidden rounded-2xl border border-border/60 bg-card/70 p-6">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.08),transparent_35%)]" aria-hidden="true"></div>
        <div class="relative flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div class="space-y-1">
            <p class="text-sm font-semibold text-foreground">Keahlian Utama</p>
            <p class="text-sm text-muted-foreground">
              Kombinasi tool dan soft skill yang paling sering dipakai.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            {stack.map((item) => (
              <span class={badgeClass({ className: "rounded-full" })}>{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
