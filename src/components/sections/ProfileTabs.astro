---
import { Image } from "astro:assets";
import {
  badgeClass,
  bentoCardClass,
  buttonClass,
  cardContentClass,
  cardHeaderClass,
  cardTitleClass,
  cx
} from "@/lib/ui";
import { getLangFromUrl, getPortfolioData } from "@/lib/data";

interface Props {
  lang?: "id" | "en";
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const isEn = lang === "en";
const data = getPortfolioData(lang);

const { education, trainings, publications } = data;

const labels = {
  sectionTitle: isEn ? "Profile" : "Profil",
  sectionDesc: isEn
    ? "Academic background, certifications, and published works."
    : "Latar belakang akademik, sertifikasi, dan karya yang dipublikasikan.",
  tabEducation: isEn ? "Education" : "Pendidikan",
  tabTrainings: isEn ? "Certifications" : "Sertifikasi",
  tabPublications: isEn ? "Publications" : "Publikasi",
  btnDetail: isEn ? "View Details" : "Lihat Detail",
  btnCert: isEn ? "View Certificate" : "Lihat Sertifikat",
};

const tabs = [
  {
    id: "education",
    label: labels.tabEducation,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-graduation-cap"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"></path><path d="M22 10v6"></path><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path></svg>`,
    count: education.length
  },
  {
    id: "trainings",
    label: labels.tabTrainings,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-award"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"></path><circle cx="12" cy="8" r="6"></circle></svg>`,
    count: trainings.length
  },
  {
    id: "publications",
    label: labels.tabPublications,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"></path><path d="M14 2v5a1 1 0 0 0 1 1h5"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg>`,
    count: publications.length
  },
];
---

<section id="profil" class="section">
  <div aria-hidden="true" class="section-bg">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_42%),radial-gradient(circle_at_bottom_right,rgba(14,165,233,0.08),transparent_40%)]"></div>
  </div>

  <div class="container relative space-y-10">
    <!-- Section Header -->
    <div class="mx-auto max-w-2xl space-y-3 text-center">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{labels.sectionTitle}</h2>
      <p class="text-base leading-relaxed text-muted-foreground md:text-lg">{labels.sectionDesc}</p>
    </div>

    <!-- Tab Buttons -->
    <div
      role="tablist"
      aria-label={labels.sectionTitle}
      class="flex flex-wrap items-center justify-center gap-2 sm:gap-3"
      id="profile-tablist"
    >
      {tabs.map((tab, i) => (
        <button
          role="tab"
          id={`tab-${tab.id}`}
          aria-controls={`panel-${tab.id}`}
          aria-selected={i === 0 ? "true" : "false"}
          data-profile-tab={tab.id}
          class={cx(
            "profile-tab-btn flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-medium transition-all duration-300",
            i === 0
              ? "border-primary bg-primary text-primary-foreground shadow-sm"
              : "border-border/60 bg-card/60 text-muted-foreground hover:border-primary/50 hover:bg-primary/10 hover:text-foreground"
          )}
        >
          <span aria-hidden="true" class="shrink-0" set:html={tab.icon} />
          <span>{tab.label}</span>
          <span class={cx(
            "rounded-full px-1.5 py-0.5 text-xs font-semibold",
            i === 0 ? "bg-primary-foreground/20 text-primary-foreground" : "bg-secondary text-muted-foreground"
          )}>
            {tab.count}
          </span>
        </button>
      ))}
    </div>

    <!-- Tab Panels -->

    <!-- Education Panel -->
    <div
      role="tabpanel"
      id="panel-education"
      aria-labelledby="tab-education"
      data-profile-panel="education"
      class="profile-tab-panel"
    >
      <div class="grid gap-6 md:grid-cols-2">
        {education.map((item) => (
          <article class={bentoCardClass("h-full")}>
            <div class={cx(cardHeaderClass, "space-y-3")}>
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex min-w-0 items-center gap-3">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-border/60 bg-secondary">
                    <Image
                      src={item.logo}
                      alt={`${item.school} logo`}
                      class="h-7 w-7 object-contain"
                      width={112}
                      quality={82}
                      format="webp"
                      loading="lazy"
                    />
                  </div>
                  <div class="min-w-0">
                    <h3 class={cx(cardTitleClass, "sm:truncate")}>{item.school}</h3>
                    <p class="mt-1 text-sm text-muted-foreground">{item.program}</p>
                  </div>
                </div>
                <span class={badgeClass({ variant: "secondary", className: "self-start rounded-full sm:self-auto sm:shrink-0" })}>
                  {item.period}
                </span>
              </div>
            </div>
            <div class={cx(cardContentClass, "space-y-3")}>
              <p class="text-sm leading-relaxed text-muted-foreground">{item.description}</p>
              {item.gpa ? <p class="text-sm font-medium text-foreground">{item.gpa}</p> : null}
              {item.url ? (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noreferrer noopener"
                  class={buttonClass({ size: "sm", variant: "outline", className: "rounded-full" })}
                >
                  {labels.btnDetail}
                </a>
              ) : null}
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Trainings Panel -->
    <div
      role="tabpanel"
      id="panel-trainings"
      aria-labelledby="tab-trainings"
      data-profile-panel="trainings"
      class="profile-tab-panel hidden"
    >
      <div class="grid gap-6 md:grid-cols-2">
        {trainings.map((training) => (
          <article class={bentoCardClass("h-full")}>
            <div class={cx(cardHeaderClass, "space-y-3")}>
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex min-w-0 items-center gap-3">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-border/60 bg-secondary">
                    <Image
                      src={training.logo}
                      alt={`${training.provider} logo`}
                      class="h-7 w-7 object-contain"
                      width={112}
                      quality={82}
                      format="webp"
                      loading="lazy"
                    />
                  </div>
                  <div class="min-w-0">
                    <h3 class={cx(cardTitleClass, "sm:truncate")}>{training.provider}</h3>
                    <p class="mt-1 text-sm text-muted-foreground">{training.program}</p>
                  </div>
                </div>
                <span class={badgeClass({ variant: "secondary", className: "self-start rounded-full sm:self-auto sm:shrink-0" })}>
                  {training.year}
                </span>
              </div>
            </div>
            <div class={cx(cardContentClass, "space-y-3")}>
              <div class="flex flex-wrap gap-2">
                {training.skills.map((skill) => (
                  <span class={badgeClass({ variant: "outline", className: "rounded-full" })}>{skill}</span>
                ))}
              </div>
              {training.url ? (
                <a
                  href={training.url}
                  target="_blank"
                  rel="noreferrer noopener"
                  class={buttonClass({ size: "sm", variant: "outline", className: "rounded-full" })}
                >
                  {labels.btnCert}
                </a>
              ) : null}
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Publications Panel -->
    <div
      role="tabpanel"
      id="panel-publications"
      aria-labelledby="tab-publications"
      data-profile-panel="publications"
      class="profile-tab-panel hidden"
    >
      <div class="grid gap-6 md:grid-cols-2">
        {publications.map((item) => (
          <article class={bentoCardClass("h-full")}>
            <div class={cx(cardHeaderClass, "space-y-3")}>
              <div class="flex items-start justify-between gap-3">
                <h3 class={cx(cardTitleClass, "min-w-0 text-lg leading-snug")}>
                  <span class="line-clamp-2">{item.title}</span>
                </h3>
                <span class={badgeClass({ variant: "secondary", className: "shrink-0 rounded-full" })}>
                  {item.year}
                </span>
              </div>
              <p class="text-sm text-muted-foreground">{item.platform}</p>
            </div>
            <div class={cx(cardContentClass, "space-y-4")}>
              {item.summary ? (
                <p class="line-clamp-3 text-sm leading-relaxed text-muted-foreground">{item.summary}</p>
              ) : null}
              <div class="flex items-center gap-3">
                <a
                  href={item.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Buka detail: ${item.title}`}
                  class={buttonClass({
                    size: "sm",
                    variant: "outline",
                    className: "rounded-full border-primary/40 hover:border-primary hover:bg-primary/10"
                  })}
                >
                  <span>{labels.btnDetail}</span>
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M5 10h10M11 6l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initProfileTabs() {
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-profile-tab]");
    const panels  = document.querySelectorAll<HTMLElement>("[data-profile-panel]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.profileTab!;

        // Update button styles
        buttons.forEach((b) => {
          const isActive = b.dataset.profileTab === target;
          b.setAttribute("aria-selected", isActive ? "true" : "false");
          b.classList.toggle("border-primary", isActive);
          b.classList.toggle("bg-primary", isActive);
          b.classList.toggle("text-primary-foreground", isActive);
          b.classList.toggle("shadow-sm", isActive);
          b.classList.toggle("border-border/60", !isActive);
          b.classList.toggle("bg-card/60", !isActive);
          b.classList.toggle("text-muted-foreground", !isActive);

          // Update count badge colours
          const badge = b.querySelector("span:last-child") as HTMLElement | null;
          if (badge) {
            badge.classList.toggle("bg-primary-foreground/20", isActive);
            badge.classList.toggle("text-primary-foreground", isActive);
            badge.classList.toggle("bg-secondary", !isActive);
            badge.classList.toggle("text-muted-foreground", !isActive);
          }
        });

        // Show/hide panels with fade animation
        panels.forEach((panel) => {
          if (panel.dataset.profilePanel === target) {
            panel.classList.remove("hidden");
            panel.style.opacity = "0";
            panel.style.transform = "translateY(8px)";
            requestAnimationFrame(() => {
              panel.style.transition = "opacity 300ms ease, transform 300ms ease";
              panel.style.opacity = "1";
              panel.style.transform = "translateY(0)";
            });
          } else {
            panel.classList.add("hidden");
            panel.style.opacity = "";
            panel.style.transform = "";
            panel.style.transition = "";
          }
        });
      });
    });
  }

  // Run on initial load and on Astro view transitions
  initProfileTabs();
  document.addEventListener("astro:page-load", initProfileTabs);
</script>
