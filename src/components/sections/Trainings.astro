---
import { Image } from "astro:assets";
import {
  badgeClass,
  buttonClass,
  cardClass,
  cardContentClass,
  cardHeaderClass,
  cardTitleClass,
  cx
} from "@/lib/ui";
import { trainings as trainingsId } from "@/data/trainings";
import { trainings as trainingsEn } from "@/data/en/trainings";

const isEn = Astro.url.pathname.includes('/en');
const trainings = isEn ? trainingsEn : trainingsId;
const sectionTitle = isEn ? "Trainings" : "Pelatihan";
const btnCert = isEn ? "View Certificate" : "Lihat Sertifikat";
---

<section id="pelatihan" class="section">
  <div aria-hidden="true" class="section-bg [mask-image:linear-gradient(to_bottom,transparent,white_10%,white_90%,transparent)]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_42%),radial-gradient(circle_at_bottom_right,rgba(14,165,233,0.08),transparent_40%)]"></div>
  </div>

  <div class="container">
    <div class="mx-auto mb-16 max-w-3xl text-center">
      <h2 class="mb-4 text-3xl font-bold text-foreground sm:text-4xl lg:text-5xl">{sectionTitle}</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {trainings.map((training) => (
        <article class={cardClass("group h-full border-border/60 bg-card/70 transition-all duration-300 hover:-translate-y-2 hover:bg-card hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] dark:hover:shadow-[0_8px_30px_rgba(255,255,255,0.05)] focus-within:ring-2 focus-within:ring-primary/40 reveal-on-scroll")}>
          <div class={cx(cardHeaderClass, "space-y-3")}>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex min-w-0 items-center gap-3">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-border/60 bg-secondary">
                  <Image
                    src={training.logo}
                    alt={`${training.provider} logo`}
                    class="h-7 w-7 object-contain"
                    width={112}
                    quality={82}
                    format="webp"
                    loading="lazy"
                  />
                </div>

                <div class="min-w-0">
                  <h3 class={cx(cardTitleClass, "sm:truncate")}>{training.provider}</h3>
                  <p class="mt-1 text-sm text-muted-foreground">{training.program}</p>
                </div>
              </div>

              <span class={badgeClass({ variant: "secondary", className: "self-start rounded-full sm:self-auto sm:shrink-0" })}>
                {training.year}
              </span>
            </div>
          </div>

          <div class={cx(cardContentClass, "space-y-3")}>
            <div class="flex flex-wrap gap-2">
              {training.skills.map((skill) => (
                <span class={badgeClass({ variant: "outline", className: "rounded-full" })}>
                  {skill}
                </span>
              ))}
            </div>

            {training.url ? (
              <a
                href={training.url}
                target="_blank"
                rel="noreferrer noopener"
                class={buttonClass({ size: "sm", variant: "outline", className: "rounded-full" })}
              >
                {btnCert}
              </a>
            ) : null}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
