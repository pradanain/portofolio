---
import { Image } from "astro:assets";
import {
  badgeClass,
  bentoCardClass,
  cardClass,
  cardContentClass,
  cardHeaderClass,
  cardTitleClass,
  cx
} from "@/lib/ui";

import { getLangFromUrl, getPortfolioData } from "@/lib/data";

interface Props {
  lang?: "id" | "en";
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const isEn = lang === "en";
const data = getPortfolioData(lang);


const { organizations } = data;
const sectionTitle = isEn ? "Organizations" : "Organisasi";
const sectionDesc = isEn 
  ? "Committee roles, communities, and social contributions." 
  : "Peran kepanitiaan, komunitas, dan kontribusi sosial.";
const btnViewAll = isEn ? "View All Organizations" : "Lihat Semua Organisasi";
---

<section id="organisasi" class="section">
  <div aria-hidden="true" class="section-bg [mask-image:linear-gradient(to_bottom,transparent,white_10%,white_90%,transparent)]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_42%),radial-gradient(circle_at_bottom_right,rgba(14,165,233,0.08),transparent_40%)]"></div>
  </div>

  <div class="container relative space-y-10">
    <div class="mx-auto max-w-2xl space-y-3 text-center">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{sectionTitle}</h2>
      <p class="text-base leading-relaxed text-muted-foreground md:text-lg">
        {sectionDesc}
      </p>
    </div>

    <div class="space-y-6 ml-1.5 sm:ml-0" data-expandable-list="organizations">
      {organizations.map((org, idx) => {
        const index = idx + 1;
        const isHidden = idx >= 3;

        return (
          <div class={`relative pl-8 ${isHidden ? 'hidden' : ''}`} data-expandable-item={isHidden ? 'true' : 'false'}>
            <div aria-hidden="true" class="absolute bottom-0 left-3 top-0 w-px bg-border/80"></div>
            <div aria-hidden="true" class="absolute left-2.25 top-8 h-3 w-3 rounded-full bg-primary ring-4 ring-background"></div>

            <article class={bentoCardClass()}>
              <div class={cx(cardHeaderClass, "space-y-3")}>
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="flex min-w-0 items-center gap-3">
                    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-border/60 bg-secondary">
                      <Image
                        src={org.logo}
                        alt={`${org.organization} logo`}
                        class="h-6 w-6 object-contain"
                        width={96}
                        quality={82}
                        format="webp"
                        loading="lazy"
                      />
                    </div>

                    <div class="min-w-0">
                      <h3 class={cx(cardTitleClass, "line-clamp-2 sm:truncate")}>{org.organization}</h3>
                      <p class="mt-1 text-sm text-muted-foreground">
                        <span class="font-medium text-foreground">{org.role}</span>
                      </p>
                    </div>
                  </div>

                  <span class={badgeClass({ variant: "secondary", className: "shrink-0 rounded-full" })}>
                    {org.period}
                  </span>
                </div>

                <p class="text-sm text-muted-foreground">{org.location}</p>
              </div>

              <div class={cx(cardContentClass, "space-y-4")}>
                {org.summary ? <p class="text-sm leading-relaxed text-foreground">{org.summary}</p> : null}

                {org.highlights?.length ? (
                  <ul class="space-y-2 pl-5 text-sm text-muted-foreground">
                    {org.highlights.map((item) => (
                      <li class="list-disc leading-relaxed">{item}</li>
                    ))}
                  </ul>
                ) : null}

                {org.skills?.length ? (
                  <div class="flex flex-wrap gap-2 pt-1">
                    {org.skills.map((skill) => (
                      <span class={badgeClass({ variant: "outline", className: "rounded-full" })}>
                        {skill}
                      </span>
                    ))}
                  </div>
                ) : null}

                <div class="pt-1 text-xs text-muted-foreground">{String(index).padStart(2, "0")}</div>
              </div>
            </article>
          </div>
        );
      })}
    </div>

    {organizations.length > 3 && (
      <div class="mt-8 flex justify-center">
        <button
          type="button"
          data-expand-button="organizations"
          class="inline-flex items-center justify-center gap-2 rounded-full border border-primary/40 bg-transparent px-6 py-2.5 text-sm font-medium text-foreground transition-colors hover:bg-primary/10 hover:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
        >
          <span data-original-text={btnViewAll} data-expanded-text={isEn ? "Show Less" : "Sembunyikan"}>{btnViewAll}</span>
          <svg class="h-4 w-4 transition-transform duration-200" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 4 4 4-4"/>
          </svg>
        </button>
      </div>
    )}
  </div>
</section>
