---
import { Image } from "astro:assets";
import {
  badgeClass,
  bentoCardClass,
  buttonClass,
  cardClass,
  cardContentClass,
  cardFooterClass,
  cardHeaderClass,
  cardTitleClass,
  cx
} from "@/lib/ui";
import type { Project } from "@/data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const visibleStack = project.stack?.slice(0, 4) ?? [];
const remainingStack = project.stack ? project.stack.length - visibleStack.length : 0;
---

<article
  class={bentoCardClass("h-full")}
>
  <div class={cx(cardHeaderClass, "space-y-3")}>
    <div class="min-w-0 space-y-1">
      <h3 class={cx(cardTitleClass, "text-center leading-snug")}>{project.title}</h3>
      <p class="text-justify text-sm leading-relaxed text-muted-foreground">{project.description}</p>
    </div>
  </div>

  <div class={cx(cardContentClass, "space-y-4")}>
    {project.image ? (
      <div class="relative overflow-hidden rounded-xl border border-border/60 bg-secondary/40">
        <Image
          src={project.image}
          alt={`Preview ${project.title}`}
          class="h-40 w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          width={960}
          quality={82}
          format="webp"
          loading="lazy"
        />
      </div>
    ) : null}

    {project.impact ? (
      <p class="text-sm leading-relaxed text-muted-foreground">
        <span class="font-medium text-foreground">Impact:</span> {project.impact}
      </p>
    ) : null}

    <div class="flex flex-wrap gap-2">
      {visibleStack.map((item) => (
        <span class={badgeClass({ variant: "outline", className: "rounded-full" })}>{item}</span>
      ))}

      {remainingStack > 0 ? (
        <span class={badgeClass({ variant: "secondary", className: "rounded-full" })}>
          +{remainingStack}
        </span>
      ) : null}
    </div>
  </div>

  {project.repoUrl || project.demoUrl ? (
    <div class={cx(cardFooterClass, "mt-auto flex flex-wrap justify-center gap-2")}>
      {project.demoUrl ? (
        <a
          href={project.demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Buka demo ${project.title}`}
          data-ga-event="project_click"
          data-ga-location="projects"
          data-ga-project={project.title}
          data-ga-type="demo"
          class={buttonClass({
            size: "sm",
            variant: "outline",
            className: "rounded-full border-primary/40 hover:border-primary hover:bg-primary/10"
          })}
        >
          Live Demo
        </a>
      ) : null}

      {project.repoUrl ? (
        <a
          href={project.repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Buka GitHub ${project.title}`}
          data-ga-event="project_click"
          data-ga-location="projects"
          data-ga-project={project.title}
          data-ga-type="repo"
          class={buttonClass({ size: "sm", className: "rounded-full" })}
        >
          <span>GitHub</span>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path
              d="M5 10h10M11 6l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      ) : null}
    </div>
  ) : null}
</article>
