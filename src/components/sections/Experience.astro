---
import { Image } from "astro:assets";
import {
  badgeClass,
  cardClass,
  cardContentClass,
  cardHeaderClass,
  cardTitleClass,
  cx
} from "@/lib/ui";
import { experiences as experiencesId } from "@/data/experience";
import { experiences as experiencesEn } from "@/data/en/experience";

const isEn = Astro.url.pathname.includes('/en');
const experiences = isEn ? experiencesEn : experiencesId;
const sectionTitle = isEn ? "Experience" : "Pengalaman";
const sectionDesc = isEn 
  ? "Professional roles and key contributions." 
  : "Peran profesional dan kontribusi utama.";
---

<section id="pengalaman" class="section">
  <div aria-hidden="true" class="section-bg">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_42%),radial-gradient(circle_at_bottom_right,rgba(14,165,233,0.08),transparent_40%)]"></div>
  </div>

  <div class="container relative space-y-10">
    <div class="mx-auto max-w-2xl space-y-3 text-center">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{sectionTitle}</h2>
      <p class="text-base leading-relaxed text-muted-foreground md:text-lg">
        {sectionDesc}
      </p>
    </div>

    <div class="space-y-6">
      {experiences.map((exp, idx) => (
        <div class="relative pl-8">
          <div aria-hidden="true" class="absolute bottom-0 left-3 top-0 w-px bg-border/80"></div>
          <div aria-hidden="true" class="absolute left-2.25 top-8 h-3 w-3 rounded-full bg-primary ring-4 ring-background"></div>

          <article class={cardClass("group border-border/60 bg-card/70 transition-all duration-300 hover:-translate-y-2 hover:bg-card hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] dark:hover:shadow-[0_8px_30px_rgba(255,255,255,0.05)] focus-within:ring-2 focus-within:ring-primary/40 reveal-on-scroll")}>
            <div class={cx(cardHeaderClass, "space-y-3")}>
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="flex min-w-0 items-center gap-3">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-border/60 bg-secondary">
                    <Image
                      src={exp.logo}
                      alt={`${exp.company} logo`}
                      class="h-6 w-6 object-contain"
                      width={96}
                      quality={82}
                      format="webp"
                      loading="lazy"
                    />
                  </div>

                  <div class="min-w-0">
                    <h3 class={cx(cardTitleClass, "truncate")}>{exp.company}</h3>

                    <p class="mt-1 text-sm text-muted-foreground">
                      <span class="font-medium text-foreground">{exp.role}</span>
                      <span class="text-muted-foreground"> · {exp.employmentType}</span>
                    </p>
                  </div>
                </div>

                <span class={badgeClass({ variant: "secondary", className: "shrink-0 rounded-full" })}>
                  {exp.period}
                </span>
              </div>

              <p class="text-sm text-muted-foreground">{exp.location}</p>
            </div>

            <div class={cx(cardContentClass, "space-y-4")}>
              {exp.summary ? <p class="text-sm leading-relaxed text-foreground">{exp.summary}</p> : null}

              {exp.highlights?.length ? (
                <ul class="space-y-2 pl-5 text-sm text-muted-foreground">
                  {exp.highlights.map((item) => (
                    <li class="list-disc leading-relaxed">{item}</li>
                  ))}
                </ul>
              ) : null}

              {exp.tech?.length ? (
                <div class="flex flex-wrap gap-2 pt-1">
                  {exp.tech.map((tech) => (
                    <span class={badgeClass({ variant: "outline", className: "rounded-full" })}>
                      {tech}
                    </span>
                  ))}
                </div>
              ) : null}

              <div class="pt-1 text-xs text-muted-foreground">{String(idx + 1).padStart(2, "0")}</div>
            </div>
          </article>
        </div>
      ))}
    </div>
  </div>
</section>
