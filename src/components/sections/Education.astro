---
import { Image } from "astro:assets";
import {
  badgeClass,
  bentoCardClass,
  buttonClass,
  cardClass,
  cardContentClass,
  cardHeaderClass,
  cardTitleClass,
  cx
} from "@/lib/ui";

import { getLangFromUrl, getPortfolioData } from "@/lib/data";

interface Props {
  lang?: "id" | "en";
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const isEn = lang === "en";
const data = getPortfolioData(lang);


const { education } = data;
const sectionTitle = isEn ? "Education" : "Pendidikan";
const btnDetail = isEn ? "View Details" : "Lihat Detail";
---

<section id="pendidikan" class="section">
  <div aria-hidden="true" class="section-bg">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_42%),radial-gradient(circle_at_bottom_right,rgba(14,165,233,0.08),transparent_40%)]"></div>
  </div>

  <div class="container">
    <div class="mx-auto mb-16 max-w-3xl text-center">
      <h2 class="mb-4 text-3xl font-bold text-foreground sm:text-4xl lg:text-5xl">{sectionTitle}</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {education.map((item) => (
        <article class={bentoCardClass("h-full")}>
          <div class={cx(cardHeaderClass, "space-y-3")}>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex min-w-0 items-center gap-3">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-border/60 bg-secondary">
                  <Image
                    src={item.logo}
                    alt={`${item.school} logo`}
                    class="h-7 w-7 object-contain"
                    width={112}
                    quality={82}
                    format="webp"
                    loading="lazy"
                  />
                </div>

                <div class="min-w-0">
                  <h3 class={cx(cardTitleClass, "sm:truncate")}>{item.school}</h3>
                  <p class="mt-1 text-sm text-muted-foreground">{item.program}</p>
                </div>
              </div>

              <span class={badgeClass({ variant: "secondary", className: "self-start rounded-full sm:self-auto sm:shrink-0" })}>
                {item.period}
              </span>
            </div>
          </div>

          <div class={cx(cardContentClass, "space-y-3")}>
            <p class="text-sm leading-relaxed text-muted-foreground">{item.description}</p>

            {item.gpa ? <p class="text-sm font-medium text-foreground">{item.gpa}</p> : null}

            {item.url ? (
              <a
                href={item.url}
                target="_blank"
                rel="noreferrer noopener"
                class={buttonClass({ size: "sm", variant: "outline", className: "rounded-full" })}
              >
                {btnDetail}
              </a>
            ) : null}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
