---
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
import { buttonClass } from "@/lib/ui";

const isEn = Astro.url.pathname.includes('/en');

const navItemsId = [
  { label: "Beranda", href: "#beranda" },
  { label: "Keahlian", href: "#keahlian" },
  { label: "Proyek", href: "#proyek" },
  { label: "Pengalaman", href: "#pengalaman" },
  { label: "Profil", href: "#organisasi" },
  { label: "Kontak", href: "#kontak" }
];

const navItemsEn = [
  { label: "Home", href: "#beranda" },
  { label: "Skills", href: "#keahlian" },
  { label: "Projects", href: "#proyek" },
  { label: "Experience", href: "#pengalaman" },
  { label: "Profile", href: "#organisasi" },
  { label: "Contact", href: "#kontak" }
];

const navItems = isEn ? navItemsEn : navItemsId;

const sectionIds = navItems.map((item) => item.href.replace("#", ""));
---

<header
  class="sticky top-0 z-40 w-full border-b border-border/60 bg-background/95 backdrop-blur-md supports-[backdrop-filter]:bg-background/60 transition-colors duration-500 ease-in-out"
  data-navbar
  data-section-ids={JSON.stringify(sectionIds)}
  data-scroll-offset="88"
>
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-border to-transparent"></div>
  <div id="scroll-progress" class="absolute bottom-0 left-0 h-[2px] bg-primary w-0 transition-all duration-150 ease-out z-50"></div>

  <div class="container flex h-16 items-center gap-3">
    <a
      href="#beranda"
      class="group inline-flex items-center gap-2 rounded-lg px-2 py-1 text-sm font-semibold tracking-[0.2em] uppercase text-foreground transition hover:bg-secondary/60 focus:outline-none focus:ring-2 focus:ring-primary/40"
      aria-label="Kembali ke Beranda"
    >
      <span class="hidden sm:inline">novanniindipradana</span>
      <span class="sm:hidden">nip</span>
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-1 lg:flex" aria-label="Navigasi utama">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link" data-nav-link>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <button
        type="button"
        id="lang-toggle"
        class={buttonClass({ variant: "outline", size: "icon" })}
        aria-label="Ganti Bahasa / Switch Language"
        title="Switch Language"
      >
        <span class="text-[11px] font-bold tracking-wider" id="lang-text">ID</span>
      </button>
      <ThemeToggle />

      <div class="lg:hidden">
        <button
          type="button"
          class={buttonClass({ variant: "outline", size: "icon" })}
          aria-label="Open menu"
          data-mobile-nav-open
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M4 5h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 19h16"></path>
          </svg>
        </button>

        <dialog class="mobile-nav-dialog" data-mobile-nav>
          <div class="mobile-nav-panel">
            <div class="flex items-center justify-between gap-4">
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground">
                novanniindipradana
              </p>

              <button
                type="button"
                class={buttonClass({ variant: "outline", size: "icon" })}
                aria-label="Close menu"
                data-mobile-nav-close
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4"
                  aria-hidden="true"
                >
                  <path d="M18 6 6 18"></path>
                  <path d="m6 6 12 12"></path>
                </svg>
              </button>
            </div>

            <nav class="mt-8 flex flex-col gap-3 text-sm font-medium" aria-label="Mobile navigation">
              {navItems.map((item) => (
                <a
                  href={item.href}
                  class="rounded-xl border border-border/60 bg-card px-4 py-3 transition hover:border-primary/40 hover:bg-secondary"
                  data-mobile-nav-link
                >
                  {item.label}
                </a>
              ))}
            </nav>
          </div>
        </dialog>
      </div>
    </div>
  </div>
</header>

<style>
  .mobile-nav-dialog {
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .mobile-nav-dialog::backdrop {
    background: rgba(15, 23, 42, 0.5);
  }

  .mobile-nav-panel {
    min-height: 100%;
    padding: 1.5rem;
    background: hsl(var(--background));
    color: hsl(var(--foreground));
    transition: background-color 500ms ease-in-out, color 500ms ease-in-out;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    white-space: nowrap;
    color: hsl(var(--muted-foreground));
    transition: background-color 150ms ease, color 150ms ease;
  }

  .nav-link:hover {
    background: hsl(var(--secondary) / 0.6);
    color: hsl(var(--foreground));
  }

  .nav-link:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px hsl(var(--primary) / 0.35);
  }

  .nav-link[data-active="true"] {
    color: hsl(var(--foreground));
    background: hsl(var(--secondary) / 0.8);
  }

  .nav-link[data-active="true"]::after {
    content: none;
  }
</style>
